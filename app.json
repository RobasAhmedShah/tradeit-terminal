{
  "expo": {
    "name": "tradit2.0",
    "slug": "tradit2.0",
    "version": "1.0.0",
    "scheme": "tradit2.0",
    "web": {
      "favicon": "./assets/image.png"
    },
    "experiments": {
      "tsconfigPaths": true
    },
    "plugins": [
      "expo-router"
    ],
    "orientation": "portrait",
    "icon": "./assets/image.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#050505",
    "splash": {
      "image": "./assets/image.png",
      "resizeMode": "contain",
      "backgroundColor": "#050505"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "backgroundColor": "#050505"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/image.png",
        "backgroundColor": "#050505"
      },
      "backgroundColor": "#050505",
      "navigationBar": {
        "backgroundColor": "#050505"
      }
    }
  }
}
