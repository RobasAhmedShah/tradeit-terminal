{
  "expo": {
    "name": "tradit2.0",
    "slug": "tradit2.0",
    "version": "1.0.0",
    "scheme": "tradit2.0",
    "web": {
      "favicon": "./assets/image.png"
    },
    "experiments": {
      "tsconfigPaths": true
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/tradit-logo.png",
          "backgroundColor": "#FF8A00",
          "resizeMode": "contain"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow TradeIt to attach photos to your community posts."
        }
      ]
    ],
    "orientation": "portrait",
    "icon": "./assets/image.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#FF8A00",
    "splash": {
      "image": "./assets/tradit-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#FF8A00"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "backgroundColor": "#FF8A00"
    },
    "android": {
      "package": "com.tradit.tradit20",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/image.png",
        "backgroundColor": "#FF8A00"
      },
      "backgroundColor": "#FF8A00",
      "navigationBar": {
        "backgroundColor": "#050505"
      }
    }
  }
}
